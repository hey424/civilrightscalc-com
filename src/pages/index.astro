---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Civil Rights Violation Damages Calculator (§ 1983) | civilrightscalc.com';
const description = 'Estimate potential damages for civil rights violations under 42 U.S.C. § 1983: compensatory, punitive, and attorney fees. Free, informational.';
---
<BaseLayout title={title} description={description}>
  <h1>Civil Rights Violation Damages Calculator</h1>
  <p><em>Reviewed by Riley Chen (RC), Employment &amp; Civil Rights Practice Lead. Updated May 2026.</em></p>
  <p>42 U.S.C. &sect; 1983 provides a federal cause of action against state and local government officials who deprive someone of constitutional or federal statutory rights under color of state law. It is the primary vehicle for suing police officers for excessive force, public officials for unlawful searches, and government entities for systemic rights violations. This calculator estimates potential recovery for &sect; 1983 claims.</p>
  <h2>Run the estimate</h2>
  <form id="calc" novalidate>
    <label for="vtype">Type of constitutional violation</label>
    <select id="vtype">
      <option value="excessive-force">Excessive force / police brutality</option>
      <option value="unlawful-arrest">Unlawful arrest or detention</option>
      <option value="search-seizure">Unlawful search or seizure</option>
      <option value="due-process">Due process violation (property or liberty)</option>
      <option value="first-amendment">First Amendment retaliation</option>
      <option value="equal-protection">Equal protection violation</option>
    </select>
    <label for="injury">Physical injury?</label>
    <select id="injury">
      <option value="serious">Yes — serious/permanent injury</option>
      <option value="moderate">Yes — moderate injury requiring treatment</option>
      <option value="minor">Minor injury</option>
      <option value="none">No physical injury (constitutional violation only)</option>
    </select>
    <label for="income">Annual income (USD)</label>
    <input id="income" type="number" value="50000" min="0" />
    <label for="months-lost">Months of lost income or detention</label>
    <input id="months-lost" type="number" value="0" min="0" max="120" />
    <label for="defendant">Primary defendant</label>
    <select id="defendant">
      <option value="municipality">Municipality / government entity (Monell claim)</option>
      <option value="officer">Individual government officer</option>
    </select>
    <button type="submit">Estimate damages</button>
  </form>
  <p id="result" aria-live="polite"></p>
  <h2>How § 1983 damages work</h2>
  <p>Section 1983 allows compensatory damages for actual harm caused by the constitutional violation &mdash; physical injury, emotional distress, lost income, and loss of constitutional rights. Punitive damages are available against individual officers who act with malice or reckless indifference but are <em>not</em> available against municipalities. Attorney fees are recoverable under 42 U.S.C. &sect; 1988.</p>
  <p>The most significant limitation is <strong>qualified immunity</strong>: individual government officials are shielded from damages unless the constitutional right they violated was &ldquo;clearly established&rdquo; at the time of the conduct. This defense has been increasingly criticized and has been restricted in some states (Colorado, New Mexico, New York City) by statute.</p>
  <h2>Monell claims against municipalities</h2>
  <p>A municipality is only liable under &sect; 1983 if the violation resulted from an official policy, custom, or practice (<em>Monell v. Dep&rsquo;t of Social Services</em>, 436 U.S. 658 (1978)). Municipalities cannot be held liable for the isolated acts of employees under a respondeat superior theory. But a policy of inadequate training that amounts to deliberate indifference to constitutional rights also qualifies (<em>City of Canton v. Harris</em>, 489 U.S. 378 (1989)).</p>
  <h2>Where to learn more</h2>
  <p>See <a href="/guides/how-section-1983-works">how section 1983 works</a>, <a href="/guides/types-of-civil-rights-violations">types of civil rights violations</a>, <a href="/guides/what-to-do-after-civil-rights-violation">what to do after a civil rights violation</a>, and <a href="/guides/common-civil-rights-misconceptions">common civil rights claim misconceptions</a>.</p>
  <script>
    document.getElementById('calc').addEventListener('submit', e => {
      e.preventDefault();
      const vtype = document.getElementById('vtype').value;
      const injury = document.getElementById('injury').value;
      const income = parseFloat(document.getElementById('income').value)||50000;
      const months = parseFloat(document.getElementById('months-lost').value)||0;
      const defendant = document.getElementById('defendant').value;
      const injuryBase = {serious:150000,moderate:50000,minor:10000,none:5000}[injury];
      const vtypeAdj = {'excessive-force':1.5,'unlawful-arrest':1.0,'search-seizure':0.8,'due-process':1.0,'first-amendment':0.9,'equal-protection':0.9}[vtype]||1.0;
      const lostIncome = (income/12)*months;
      const comp = (injuryBase * vtypeAdj) + lostIncome;
      const punitive = defendant==='officer' ? comp*1.2 : 0;
      const total = comp + punitive;
      const fmt = n=>'$'+Math.round(n).toLocaleString();
      document.getElementById('result').innerHTML =
        `<strong>Estimated range: ${fmt(total*0.5)} &ndash; ${fmt(total*1.5)}</strong><br>Compensatory: ${fmt(comp)} &bull; Punitive (individual officer only): ${fmt(punitive)}<br><em>Qualified immunity significantly affects individual officer claims. Attorney fees separately recoverable. Wide range reflects liability complexity.</em>`;
    });
  </script>
</BaseLayout>
